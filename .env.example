MDMED_BASE_URL=https://homologapil.mdmed.clinic/api/v1
MDMED_TOKEN=seu_token_aqui

MAISCHAT_BASE_URL=https://api.maischat.io/v3
MAISCHAT_TOKEN=seu_token_maischat
MAISCHAT_BROKER=wppCloudAPI
MAISCHAT_APP_ID=seu_app_id_meta
MAISCHAT_SOURCE=numero_remetente
MAISCHAT_META_TOKEN=seu_meta_token
MAISCHAT_TEMPLATE_NAME=confirma_agendamento_4
MAISCHAT_TEMPLATE_LEMBRETE=lembrete
MAISCHAT_TEMPLATE_LANGUAGE=pt_BR
MAISCHAT_DEFAULT_COUNTRY_CODE=55

TIMEZONE=America/Sao_Paulo
PORT=3000

# ─── Janelas de tempo (em dias) ───────────────────────────────────────────────
# Quantos dias antes da consulta o cron de confirmação dispara.
DIAS_CONFIRMACAO=5
# Quantos dias antes da consulta o cron de lembrete dispara.
DIAS_LEMBRETE=3
# Janela usada por /confirmar-mais-recente e /cancelar-mais-recente quando o
# webhook chega sem DataAgendamento (busca agendamentos futuros nessa janela).
DIAS_JANELA_RESPOSTA=30
# Janela usada para auto-desambiguar família (telefone com múltiplos pacientes)
# quando o webhook não envia DataAgendamento.
DIAS_AUTO_DESAMBIGUACAO=7
# Tolerância em dias usada por escolherAgendamento ao buscar por janela.
DIAS_TOLERANCIA_ESCOLHA=2

# ─── Cache de lote (anti-duplicação) ──────────────────────────────────────────
# Entradas de cache-lote.json cuja data do agendamento já passou há mais de
# CACHE_LOTE_RETENCAO_DIAS dias são removidas automaticamente.
CACHE_LOTE_RETENCAO_DIAS=7

# ─── Crons
#False para Teste
#True para produção
CRON_LOTE_EXPR=0 8 * * *
CRON_LOTE_ATIVO=true
CRON_LEMBRETE_EXPR=0 8 * * *
CRON_LEMBRETE_ATIVO=true
